# ───── MalariaWatch Backend Configuration ─────

# Development (SQLite — default, no setup needed)
DATABASE_URL=sqlite:///./malariawatch.db

# Production — Supabase PostgreSQL
# 1. Create project at https://supabase.com
# 2. Go to Settings → Database → Connection string
# 3. Copy the URI and replace [YOUR-PASSWORD] with your database password
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Production — Railway PostgreSQL
# Railway auto-injects this when you provision a PostgreSQL service
# DATABASE_URL=postgresql://postgres:...

UPLOAD_DIR=./uploads
MODEL_DIR=./models
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# JWT Secret (change in production!)
JWT_SECRET=change-me-in-production-use-random-string
