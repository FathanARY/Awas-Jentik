# ───── MalariaWatch Backend Configuration ─────

# Development (SQLite — default, no setup needed)
# DATABASE_URL=sqlite:///./malariawatch.db

# Production — Supabase PostgreSQL
# 1. Create project at https://supabase.com
# 2. Go to Settings → Database → Connection string
# 3. Copy the URI and replace [YOUR-PASSWORD] with your database password
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.bhknqrmtdlvkacrnqgla.supabase.co:5432/postgres

# Production — Railway PostgreSQL (auto-injected by Railway)
# DATABASE_URL is set automatically

UPLOAD_DIR=./uploads
MODEL_DIR=./models

# Allow frontend domains (comma-separated)
CORS_ORIGINS=http://localhost:3000,https://malariawatch.vercel.app

# JWT Secret (change in production!)
JWT_SECRET=change-me-in-production-use-random-string
